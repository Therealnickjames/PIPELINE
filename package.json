{
  "name": "pipeline-controller",
  "version": "1.1.0",
  "description": "Battle-hardened gate-enforced development pipeline controller",
  "main": "lib/service.js",
  "bin": {
    "pipeline": "./bin/pipeline.js"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "coverage": "c8 --reporter=text --reporter=json-summary node --test test/**/*.test.js",
    "soak": "node test/integration/soak-runner.js",
    "ci": "npm run coverage && npm run test:integration"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
