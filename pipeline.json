{
  "schema_version": 2,
  "repo_path": ".",
  "default_branch": "main",
  "branch_prefix": "slice/",
  "test_command": "npm test",
  "scoped_test_command_template": "",
  "db_path": "pipeline.db",
  "signal_dir": "signals",
  "artifacts_dir": "artifacts",
  "dispatcher": {
    "type": "signal-file",
    "timeout_minutes": 60,
    "poll_interval_seconds": 30,
    "command": {
      "exec": [],
      "timeout_seconds": 60,
      "cwd": ".",
      "env_allowlist": []
    }
  },
  "runtime": {
    "lease_ttl_seconds": 120,
    "heartbeat_seconds": 30,
    "command_output_limit_kb": 256,
    "stale_execution_timeout_seconds": 7200
  },
  "github": {
    "remote": "origin",
    "timeout_seconds": 60,
    "gh_exec": [
      "gh"
    ]
  },
  "hooks": {
    "failure_memory_lookup": {
      "enabled": true,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": []
    },
    "post_edit": {
      "enabled": false,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": [],
      "command": ""
    },
    "pre_commit": {
      "enabled": false,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": [],
      "command": ""
    },
    "quality_gate": {
      "enabled": true,
      "minimum_coverage": 90,
      "coverage": {
        "exec": [
          "node",
          "scripts/pipeline-quality/write-coverage-report.js"
        ],
        "report_path": "artifacts/quality-gates/reports/coverage.json",
        "metric_path": "coverage.percent"
      },
      "mutation": {
        "exec": [
          "node",
          "scripts/pipeline-quality/write-mutation-report.js"
        ],
        "report_path": "artifacts/quality-gates/reports/mutation.json",
        "pass_field": "passed"
      },
      "coverage_command": "npm run coverage",
      "mutation_command": "npm run mutation"
    },
    "post_test": {
      "enabled": true,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": [],
      "command": ""
    },
    "pre_pr": {
      "enabled": true,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": [],
      "command": ""
    },
    "post_merge": {
      "enabled": true,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": [],
      "actions": [
        "update_codemap",
        "update_backlog"
      ]
    },
    "on_failure": {
      "enabled": true,
      "exec": [],
      "timeout_seconds": 30,
      "cwd": ".",
      "env_allowlist": []
    }
  },
  "auto_fix": {
    "enabled": true,
    "max_attempts": 1,
    "agent_type": "codex",
    "timeout_minutes": 30
  },
  "notifications": {
    "enabled": true,
    "provider": "console",
    "blocked_timeout_hours": 2
  },
  "codemap": {
    "path": "codemap.json",
    "conventions": [
      "CommonJS (require/module.exports)",
      "Node 22+",
      "better-sqlite3 for DB operations",
      "No TypeScript"
    ]
  }
}
